# Burjeel Smart Care - Environment Variables Template
# Copy this file to .env.local and fill in your values

# API Configuration
# Points to backend API server
VITE_API_BASE_URL=http://localhost:8000/api

# WebSocket Configuration
# For real-time chat and notifications
VITE_WS_URL=ws://localhost:8000

# Application Configuration
VITE_APP_NAME=Burjeel Smart Care
VITE_APP_VERSION=1.0.0

# ============================================
# PRODUCTION VALUES (example)
# ============================================
# VITE_API_BASE_URL=https://api.burjeel.com/api
# VITE_WS_URL=wss://api.burjeel.com
